# SkillNova Security | Security-Hardened Gitignore

# Core Libraries
node_modules
dist
dist-ssr
*.local

# Secrets & Environment Nodes
.env
.env.*
!.env.example

# Local Identity Matrix (User Data)
server/users.json

# AI Backend Staging (Python)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
ai_backend/.env

# Logs & Debugging
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
out.txt
test_api_out.json
test_res.json
